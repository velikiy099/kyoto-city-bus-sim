{
  "name": "kyoto-bus-18-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build-data": "node tools/build-route-data.mjs",
    "map": "node tools/render-map.mjs",
    "map-check": "node tools/render-map.mjs --check",
    "world:download": "node tools/world/download-sources.mjs",
    "world:select": "node tools/world/select-citygml.mjs",
    "world:build": "node tools/world/build-world.mjs",
    "world:refresh": "node tools/world/build-world.mjs --refresh-osm",
    "world:validate": "node tools/world/validate-world-data.mjs",
    "world:all": "npm run world:download && npm run world:build",
    "validate:plateau-integration": "node tools/validate-plateau-integration.mjs",
    "validate:terrain-fix": "node tools/validate-terrain-fix.mjs",
    "validate:world-alignment": "node tools/validate-world-alignment.mjs"
  },
  "dependencies": {
    "three": "^0.170.0"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}
